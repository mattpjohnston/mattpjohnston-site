---
const nowItems = [
  {
    colorClass: "bg-emerald-400",
    text: "Building new UI features with React and TypeScript.",
  },
  {
    colorClass: "bg-indigo-400",
    text: "Keeping this site infrastructure running on AWS with Terraform.",
  },
  {
    colorClass: "bg-amber-400",
    text: "Improving my deployment workflows.",
  },
];
---

<section class="py-16 md:py-20">
  <div class="ui-now-surface mx-auto max-w-4xl rounded-2xl p-8 md:p-10">
    <h2 class="mb-6 text-3xl font-semibold tracking-tight text-white md:text-[2rem]">Currently</h2>
    <ul class="space-y-4 text-lg leading-relaxed text-slate-300 md:text-[1.35rem]">
      {
        nowItems.map((item) => (
          <li class="flex items-center gap-3">
            <span class:list={["h-2 w-2 shrink-0 rounded-full", item.colorClass]}></span>
            <span>{item.text}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
