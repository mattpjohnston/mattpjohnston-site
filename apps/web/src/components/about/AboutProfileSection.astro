---
import GitHubIcon from "../icons/GitHubIcon.astro";
import LinkedInIcon from "../icons/LinkedInIcon.astro";
import MailIcon from "../icons/MailIcon.astro";

const socialButtonClass =
  "ui-about-social ui-icon-action ui-text-muted inline-flex h-11 w-11 items-center justify-center rounded-full border hover:text-indigo-300";
const personalInterests = [
  "Formula 1 🏎️",
  "Travel and photography 📷",
  "Health and fitness 🏋️",
  "Art galleries and museums 🖼️"
];
---

<section class="pb-14 pt-20 md:pt-24">
  <div class="grid gap-12 md:grid-cols-[1.05fr_0.95fr] md:items-start">
    <div>
      <h1 class="text-5xl font-semibold tracking-tight text-white md:text-6xl">About Me</h1>

      <p class="mt-8 max-w-2xl text-xl leading-relaxed text-slate-400 md:text-2xl">
        I work with Linux and IT infrastructure, and I spend a lot of my free time building things for the web.
      </p>

      <p class="mt-7 max-w-2xl text-xl leading-relaxed text-slate-400 md:text-2xl">
        I enjoy full-stack projects and solving problems. Most of my software development work so far has been React, JavaScript, and Node/Express; but I'm quite interested in other programming laguages like Java, C#, and Rust. I am also an experienced IT infrastructure engineer.
      </p>

      <nav aria-label="Social links" class="mt-10">
        <ul class="flex items-center gap-3">
          <li>
            <a
              href="https://github.com/mattpjohnston"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
              class={socialButtonClass}
            >
              <GitHubIcon class="h-5 w-5" />
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/mattpjohnston"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class={socialButtonClass}
            >
              <LinkedInIcon class="h-5 w-5" />
            </a>
          </li>
          <li>
            <a
              href="/contact/"
              aria-label="Contact"
              class={socialButtonClass}
            >
              <MailIcon class="h-5 w-5" />
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="space-y-4 rounded-2xl p-0">
      <div class="ui-photo-frame min-h-88 overflow-hidden rounded-2xl shadow-[0_18px_42px_rgba(2,10,34,0.45)] md:min-h-104">
        <img
          src="/assets/me.jpg"
          alt="Portrait of Matthew Johnston"
          class="h-full w-full object-cover object-center"
          loading="eager"
          decoding="async"
        />
      </div>

      <section class="ui-surface-gradient rounded-xl p-5">
        <h2 class="text-xl font-semibold tracking-tight text-white">My interests outside of coding</h2>
        <ul class="mt-3 space-y-2 text-base leading-relaxed text-slate-300">
          {
            personalInterests.map((interest) => (
              <li class="flex items-start gap-2">
                <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-400"></span>
                <span>{interest}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </div>
</section>
