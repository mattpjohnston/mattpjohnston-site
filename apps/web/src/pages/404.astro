---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "404";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="mx-auto flex min-h-[62vh] max-w-2xl flex-col justify-center pb-16 pt-14 md:min-h-[66vh] md:pb-20 md:pt-20">
    <p class="ui-text-muted font-mono text-sm">Error 404</p>
    <h1 class="mt-2 text-5xl font-semibold tracking-tight text-white md:text-6xl">Page not found</h1>
    <p class="mt-5 text-xl leading-relaxed text-slate-400 md:text-2xl">
      The page you were looking for doesn&apos;t exist or has moved.
    </p>

    <div class="ui-surface-gradient mt-8 rounded-2xl p-6 md:p-7">
      <p class="text-base text-slate-300 md:text-lg">
        Try one of these routes instead:
      </p>
      <nav aria-label="Fallback links" class="mt-5 flex flex-wrap justify-center gap-4 md:justify-start">
        <a
          href="/"
          class="ui-btn-primary inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-7 py-3 text-base font-medium text-white shadow-lg shadow-indigo-500/20 hover:bg-indigo-500"
        >
          Go home <span aria-hidden="true">→</span>
        </a>
        <a
          href="/projects/"
          class="ui-btn-secondary inline-flex items-center rounded-xl border border-white/10 bg-slate-800 px-7 py-3 text-base font-medium text-slate-100 hover:bg-slate-700"
        >
          View projects
        </a>
        <a
          href="/blog/"
          class="ui-btn-secondary inline-flex items-center rounded-xl border border-white/10 bg-slate-800 px-7 py-3 text-base font-medium text-slate-100 hover:bg-slate-700"
        >
          Read blog
        </a>
      </nav>
    </div>
  </section>
</BaseLayout>
